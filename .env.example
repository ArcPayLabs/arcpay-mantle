MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
MANTLE_EXPLORER_URL=https://sepolia.mantlescan.xyz
MANTLESCAN_API_URL=https://api-sepolia.mantlescan.xyz/api
MANTLESCAN_API_KEY=

PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
MANTLE_AGENT_PLATFORM=
MANTLE_RISK_AGENT_ID=13174292974160097713
USDY_TOKEN_ADDRESS=

# Frontend API sessions and optional Supabase persistence.
ARCPAY_SESSION_SECRET=replace-with-32-byte-random-secret
ARCPAY_RECORDS_TABLE=arcpay_mantle_records
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ARCPAY_ADMIN_WALLETS=

# Optional if you later add client-side Supabase reads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=https://arcpay-mantle.vercel.app
NEXT_PUBLIC_X402_SERVER_URL=https://mantle-x402.20.208.46.195.nip.io

# Optional RealClaw / Byreal handoff configuration.
# RealClaw owns the Telegram bot token. Do not store that token in ArcPay.
REALCLAW_AGENT_URL=
REALCLAW_AGENT_ADDRESS=
REALCLAW_TELEGRAM_BOT_CONFIGURED=false
BYREAL_AGENT_SKILLS_PATH=
BYREAL_PERPS_CLI_PATH=

# Hosted x402 gateway and backend worker.
X402_SERVER_PORT=4033
X402_ALLOWED_ORIGIN=https://arcpay-mantle.vercel.app
X402_PROVIDER_PRIVATE_KEY=
X402_ADMIN_SECRET=
ARCPAY_WORKER_CHECKPOINT_PATH=.arcpay-mantle-worker-checkpoint.json
ARCPAY_WORKER_BACKFILL_BLOCKS=5000
ARCPAY_WORKER_POLL_MS=12000

# Optional hosted MCP-style HTTP bridge controls.
# If set, /api/mcp requires Authorization: Bearer <token>.
ARCPAY_MCP_BEARER_TOKEN=
ARCPAY_MCP_RATE_LIMIT_PER_MINUTE=60
